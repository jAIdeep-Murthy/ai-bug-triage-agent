# Copy to .env and fill in. Never commit real secrets.

# Jira Cloud (all required for live mode; omit any to use mock Jira in dev)
JIRA_BASE_URL=
# Use either JIRA_EMAIL or JIRA_USER (email is typical for Cloud API tokens)
JIRA_EMAIL=
JIRA_USER=
JIRA_API_TOKEN=

# Local Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
MODEL_NAME=qwen2.5:7b

# Demo mode (bypass Ollama with a hardcoded realistic analysis result)
DEMO_MODE=true

# SQLite database URL (used in later units)
DATABASE_URL=sqlite:///./data/bug_triage.db
